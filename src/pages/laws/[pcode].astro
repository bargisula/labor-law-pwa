---
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../data/laws/*.json', { eager: true });
  return Object.entries(modules)
    .filter(([file]) => !file.endsWith('index.json'))
    .map(([, mod]) => {
      const law = (mod as any).default ?? mod;
      return { params: { pcode: law.pcode }, props: { law } };
    });
}

const { law } = Astro.props;
let lastChapter = '';
---
<Layout title={`${law.name}｜勞基法查詢`} description={`${law.name}全文，共 ${law.articles.length} 條`}>
  <nav class="breadcrumb"><a href="/">← 回搜尋</a></nav>
  <h1>{law.name}</h1>
  <p class="muted">
    最新異動：{law.updated}・
    <a href={law.sourceUrl} target="_blank" rel="noopener">官方原文</a>
  </p>

  {law.articles.map((a) => {
    const showChapter = a.chapter && a.chapter !== lastChapter;
    lastChapter = a.chapter || lastChapter;
    return (
      <>
        {showChapter && <h2 class="chapter">{a.chapter}</h2>}
        <article class="card article" id={`art-${a.id}`}>
          <h3>{a.no}</h3>
          <p class="content">{a.content}</p>
        </article>
      </>
    );
  })}
</Layout>

<style>
  .breadcrumb { margin: 0.5rem 0; }
  .breadcrumb a { text-decoration: none; }
  h1 { font-size: 1.4rem; margin: 0.5rem 0 0.25rem; }
  .muted { color: var(--muted); font-size: 0.85rem; }
  .chapter {
    font-size: 1rem;
    color: var(--brand);
    margin: 1.5rem 0 0.5rem;
  }
  .article h3 { margin: 0 0 0.25rem; font-size: 1rem; color: var(--brand-dark); }
  @media (prefers-color-scheme: dark) {
    .article h3 { color: var(--brand); filter: brightness(1.4); }
  }
  .content { margin: 0; white-space: pre-line; }
  .article:target { border-color: var(--brand); box-shadow: 0 0 0 2px var(--brand); }
  .article { scroll-margin-top: 4rem; }
</style>
